# Server Configuration
PORT=8080

# OneBusAway API Configuration
ONEBUSAWAY_API_KEY=test
ONEBUSAWAY_BASE_URL=https://api.pugetsound.onebusaway.org

# Optional brand name
# APP_BRAND_NAME=OneBusAway

# Alternative OneBusAway Servers (choose one):
# ONEBUSAWAY_BASE_URL=https://api.tampa.onebusaway.org              # Tampa, FL (HART)
# ONEBUSAWAY_BASE_URL=https://api.unitrans.onebusawaycloud.com      # Davis, CA (Unitrans)
# ONEBUSAWAY_BASE_URL=http://localhost:8080                         # Local development server

# Localization Configuration
# Comma-separated list of supported language codes
# Available: en-US, es-US, fr-FR, de-DE, ar-SA, ko-KR, pl-PL, pt-BR, ru-RU, zh-CN
SUPPORTED_LANGUAGES=en-US

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# Analytics Configuration (optional)
ANALYTICS_ENABLED=false

# Required if ANALYTICS_ENABLED=true
# Generate with: openssl rand -base64 32
# ANALYTICS_HASH_SALT=your_32_char_random_salt_here

# Optional analytics tuning
# ANALYTICS_WORKER_COUNT=4
# ANALYTICS_QUEUE_SIZE=1000
# ANALYTICS_SHUTDOWN_TIMEOUT=30

# Plausible Analytics Provider (optional)
PLAUSIBLE_ENABLED=false

# Required if PLAUSIBLE_ENABLED=true
# PLAUSIBLE_DOMAIN=your-domain.com

# Optional Plausible configuration
# PLAUSIBLE_API_URL=https://plausible.io
# PLAUSIBLE_API_KEY=your_plausible_api_key
# PLAUSIBLE_BATCH_SIZE=50
# PLAUSIBLE_FLUSH_INTERVAL=30
# PLAUSIBLE_HTTP_TIMEOUT=10
# PLAUSIBLE_MAX_RETRIES=3
# PLAUSIBLE_RETRY_DELAY=1

# Arrival anomaly filter (optional)
# Exclude records where predicted is unrealistically earlier than scheduled.
ARRIVAL_FILTER_ENABLED=false
ARRIVAL_FILTER_SMS_MAX_EARLY_MINUTES=20
ARRIVAL_FILTER_VOICE_MAX_EARLY_MINUTES=15
# If filtering removes all arrivals, return unfiltered list instead.
ARRIVAL_FILTER_FALLBACK_TO_UNFILTERED=true